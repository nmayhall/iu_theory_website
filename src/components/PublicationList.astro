---
import type { CollectionEntry } from 'astro:content';
import { groupByYear, linkFor } from '../lib/publications';

interface Props {
  publications: CollectionEntry<'publications'>[];
  /** Surnames to emphasise in author lists (the faculty on this page). */
  highlight?: string[];
}

const { publications, highlight = [] } = Astro.props;
const groups = groupByYear(publications);

const isHighlighted = (author: string) => {
  const last = author.trim().split(/\s+/).pop()?.toLowerCase() ?? '';
  return highlight.includes(last);
};
---

{
  groups.length === 0 ? (
    <p class="lede">No publications listed yet.</p>
  ) : (
    groups.map((group) => (
      <section class="pub-year">
        <h3>{group.year ?? 'Undated'}</h3>
        <ul>
          {group.items.map((pub) => {
            const href = linkFor(pub);
            return (
              <li>
                <p class="pub-title">
                  {href ? <a href={href}>{pub.data.title}</a> : pub.data.title}
                </p>
                <p class="pub-authors">
                  {pub.data.authors.map((a, i) => (
                    <>
                      {i > 0 && ', '}
                      {isHighlighted(a) ? <strong>{a}</strong> : a}
                    </>
                  ))}
                </p>
                <p class="pub-meta">
                  {pub.data.journal && <em>{pub.data.journal}</em>}
                  {pub.data.volume && <> <strong>{pub.data.volume}</strong></>}
                  {pub.data.pages && <>, {pub.data.pages}</>}
                  {pub.data.year && <> ({pub.data.year})</>}
                </p>
              </li>
            );
          })}
        </ul>
      </section>
    ))
  )
}

<style>
  .pub-year {
    margin-bottom: 2rem;
  }

  .pub-year h3 {
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    color: var(--crimson);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 0.4rem;
    margin-bottom: 0.75rem;
  }

  .pub-year ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .pub-year li {
    padding-block: 0.85rem;
    max-width: var(--measure);
  }

  .pub-year li + li {
    border-top: 1px solid var(--rule);
  }

  .pub-title {
    margin: 0 0 0.2rem;
    font-size: 1.0625rem;
    line-height: 1.35;
  }

  .pub-title a {
    color: inherit;
    text-decoration: none;
  }

  .pub-title a:hover {
    color: var(--crimson);
    text-decoration: underline;
  }

  .pub-authors,
  .pub-meta {
    margin: 0;
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.875rem;
    color: var(--muted);
  }

  .pub-authors strong {
    color: var(--ink);
  }
</style>
