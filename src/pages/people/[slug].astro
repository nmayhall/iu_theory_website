---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { url } from '../../lib/url';

// One page per faculty entry. The entry id (the markdown filename) is the slug, which is
// the same id research entries reference.
export const getStaticPaths: GetStaticPaths = async () => {
  const faculty = await getCollection('faculty');
  return faculty.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
};

interface Props {
  entry: CollectionEntry<'faculty'>;
}

const { entry } = Astro.props;
const { name, title, photo, researchAreas, personalSite, googleScholar, awards, education } =
  entry.data;
const { Content } = await render(entry);

// Research thrusts this person is attached to, so the bio links back into /research.
const thrusts = (await getCollection('research'))
  .filter((thrust) => thrust.data.faculty.some((ref) => ref.id === entry.id))
  .sort((a, b) => a.data.order - b.data.order);

const initials = name
  .split(/\s+/)
  .map((part) => part[0])
  .slice(0, 2)
  .join('');
---

<BaseLayout title={`${name} — IU Theoretical Chemistry`} description={`${name}, ${title}.`}>
  <p class="eyebrow"><a href={url('/people')}>← People</a></p>

  <div class="bio-head">
    <div class="bio-photo">
      {
        photo ? (
          <Image src={photo} alt={`Portrait of ${name}`} width={640} />
        ) : (
          <div class="initials" aria-hidden="true">
            {initials}
          </div>
        )
      }
    </div>

    <div class="bio-meta">
      <h1>{name}</h1>
      <p class="role">{title}</p>

      {
        researchAreas.length > 0 && (
          <ul class="tags">
            {researchAreas.map((area) => (
              <li>{area}</li>
            ))}
          </ul>
        )
      }

      {
        (personalSite || googleScholar) && (
          <p class="links">
            {personalSite && <a href={personalSite}>Group site</a>}
            {googleScholar && <a href={googleScholar}>Google Scholar</a>}
          </p>
        )
      }
    </div>
  </div>

  <div class="bio-body">
    <div class="prose">
      <Content />
    </div>

    <aside class="bio-aside">
      {
        education.length > 0 && (
          <section>
            <h2>Education</h2>
            <ul class="plain">
              {education.map((line) => (
                <li>{line}</li>
              ))}
            </ul>
          </section>
        )
      }

      {
        awards.length > 0 && (
          <section>
            <h2>Selected honors</h2>
            <ul class="plain">
              {awards.map((award) => (
                <li>
                  {award.year && <span class="award-year">{award.year}</span>}
                  <span>{award.name}</span>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {
        thrusts.length > 0 && (
          <section>
            <h2>Research thrusts</h2>
            <ul class="plain">
              {thrusts.map((thrust) => (
                <li>
                  <a href={url('/research')}>{thrust.data.title}</a>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </aside>
  </div>
</BaseLayout>

<style>
  .bio-head {
    display: grid;
    grid-template-columns: minmax(0, 220px) 1fr;
    gap: 2rem;
    align-items: start;
    margin-bottom: 2.5rem;
  }

  .bio-photo :global(img),
  .bio-photo .initials {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 3px;
    background: var(--wash);
  }

  .bio-photo .initials {
    display: grid;
    place-items: center;
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 2.75rem;
    font-weight: 600;
    color: #b9b4ae;
    border: 1px dashed var(--rule);
  }

  .bio-meta h1 {
    margin-bottom: 0.25rem;
  }

  .bio-meta .role {
    color: var(--muted);
    margin: 0 0 1rem;
  }

  .bio-body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 280px);
    gap: 3rem;
    align-items: start;
    border-top: 1px solid var(--rule);
    padding-top: 2rem;
  }

  .bio-aside section {
    margin-bottom: 2rem;
  }

  .bio-aside h2 {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--crimson);
    margin-bottom: 0.6rem;
  }

  .plain {
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.875rem;
  }

  .plain li {
    padding-block: 0.4rem;
    border-bottom: 1px solid var(--rule);
    display: flex;
    gap: 0.6rem;
  }

  .plain a {
    display: flex;
    align-items: center;
    min-height: 44px;
  }

  .award-year {
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    flex: none;
  }

  @media (max-width: 46rem) {
    .bio-head {
      grid-template-columns: minmax(0, 160px) 1fr;
      gap: 1.25rem;
    }

    .bio-body {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
