---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';

const thrusts = (await getCollection('research')).sort((a, b) => a.data.order - b.data.order);

// Resolve faculty references once into an id -> name lookup, rather than issuing a
// getEntry() call per reference.
const facultyById = new Map(
  (await getCollection('faculty')).map((entry) => [entry.id, entry.data.name]),
);

// reference() only checks that the *shape* is right; it does not verify the target
// exists until something dereferences it. Without this guard a typo'd slug renders
// as an empty name instead of failing, so resolve eagerly and fail loudly.
function facultyName(id: string): string {
  const name = facultyById.get(id);
  if (!name) {
    throw new Error(
      `Unknown faculty slug "${id}" referenced in a research entry. ` +
        `Expected one of: ${[...facultyById.keys()].join(', ')}`,
    );
  }
  return name;
}

// Motifs are inlined as raw SVG so they inherit `currentColor` and follow the theme.
// They are decorative placeholders — a real `figure` on an entry takes precedence.
const motifs = import.meta.glob<string>('../assets/motifs/*.svg', {
  query: '?raw',
  import: 'default',
  eager: true,
});
const motifByName = new Map(
  Object.entries(motifs).map(([path, svg]) => [path.split('/').pop()!.replace('.svg', ''), svg]),
);

const rendered = await Promise.all(
  thrusts.map(async (thrust) => ({ thrust, Content: (await render(thrust)).Content })),
);
---

<BaseLayout title="Research — IU Theoretical Chemistry">
  <p class="eyebrow">Research</p>
  <h1>Research Thrusts</h1>
  <p class="lede">
    Our work is organized around a few broad thrusts, though most projects draw on more
    than one and many are collaborative across groups.
  </p>

  <div class="section">
    {
      rendered.map(({ thrust, Content }) => {
        const motif = thrust.data.motif ? motifByName.get(thrust.data.motif) : undefined;
        return (
          <article class="thrust thrust-grid">
            <div class="thrust-art">
              {thrust.data.figure ? (
                <figure>
                  <Image src={thrust.data.figure} alt={thrust.data.figureAlt ?? ''} width={640} />
                  {thrust.data.figureCredit && <figcaption>{thrust.data.figureCredit}</figcaption>}
                </figure>
              ) : (
                motif && <div class="motif" set:html={motif} />
              )}
            </div>

            <div class="thrust-body">
              <h3>{thrust.data.title}</h3>
              <p>{thrust.data.summary}</p>
              <div class="prose">
                <Content />
              </div>
              {thrust.data.faculty.length > 0 && (
                <p class="who">
                  Faculty: {thrust.data.faculty.map((ref) => facultyName(ref.id)).join(', ')}
                </p>
              )}
            </div>
          </article>
        );
      })
    }
  </div>
</BaseLayout>

<style>
  .thrust-grid {
    display: grid;
    grid-template-columns: minmax(0, 260px) minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  /* Grid items default to min-width:auto, so a wide indivisible child — a KaTeX
     display equation — sets the column's minimum and widens the page, defeating the
     equation's own overflow-x container. Allow the columns to shrink. */
  .thrust-art,
  .thrust-body {
    min-width: 0;
  }

  .thrust-art .motif {
    color: var(--crimson);
    background: var(--wash);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 0.5rem;
  }

  .thrust-art :global(svg) {
    display: block;
    width: 100%;
    height: auto;
  }

  .thrust-art figure {
    margin: 0;
  }

  .thrust-art figcaption {
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.75rem;
    color: var(--muted);
    margin-top: 0.4rem;
  }

  .thrust-body h3 {
    margin-top: 0;
  }

  @media (max-width: 46rem) {
    .thrust-grid {
      grid-template-columns: minmax(0, 1fr);
      gap: 1.25rem;
    }

    /* On a phone the artwork is decoration competing with the text for the top of
       the screen, so cap it rather than letting it fill the full column width. */
    .thrust-art {
      max-width: 220px;
    }
  }
</style>
