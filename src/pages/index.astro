---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import heroLight from '../assets/brand/lockup-light.svg?url';
import heroDark from '../assets/brand/lockup-dark.svg?url';
import { url } from '../lib/url';

const thrusts = (await getCollection('research')).sort((a, b) => a.data.order - b.data.order);

const faculty = (await getCollection('faculty')).sort((a, b) => a.data.order - b.data.order);

const news = (await getCollection('news'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const dateFmt = new Intl.DateTimeFormat('en-US', { dateStyle: 'long', timeZone: 'UTC' });
---

<BaseLayout title="Theoretical Chemistry — Indiana University">
  {/* The lockup *is* the page heading, so it stays inside the h1 and carries the alt
      text — the document keeps a real, readable h1 for screen readers and search. */}
  <h1 class="hero-mark">
    <img
      class="brand-light"
      src={heroLight}
      alt="Theoretical Chemistry — Indiana University"
      width="1104"
      height="261"
    />
    <img
      class="brand-dark"
      src={heroDark}
      alt="Theoretical Chemistry — Indiana University"
      width="1104"
      height="261"
    />
  </h1>
  <p class="lede">
    We build the theory, algorithms, and software that explain chemical behavior from
    first principles — from strongly correlated electrons to light-driven dynamics —
    and we train the next generation of theorists to do the same.
  </p>

  <section class="section first">
    <div class="section-head">
      <h2>Research</h2>
      <a href={url('/research')}>All research →</a>
    </div>
    {/* Titles only — the summaries live on /research, so repeating them here just
        duplicated that page. Each links to its section there. */}
    <ul class="topics">
      {
        thrusts.map((thrust) => (
          <li>
            <a href={url(`/research#${thrust.id}`)}>{thrust.data.title}</a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="section">
    <div class="section-head">
      <h2>Groups</h2>
      <a href={url('/people')}>All people →</a>
    </div>
    {/* Each group: the PI's name links to their profile here; a second link goes out to
        the group's own website. */}
    <ul class="groups">
      {
        faculty.map((f) => (
          <li>
            <a class="g-name" href={url(`/people/${f.id}`)}>{f.data.name}</a>
            {f.data.personalSite && (
              <a
                class="g-site"
                href={f.data.personalSite}
                target="_blank"
                rel="noopener noreferrer"
              >
                Group site ↗
              </a>
            )}
          </li>
        ))
      }
    </ul>
  </section>

  <section class="section">
    <div class="section-head">
      <h2>News</h2>
      <a href={url('/join')}>Openings →</a>
    </div>
    {
      news.length === 0 ? (
        <p class="lede">No news items yet.</p>
      ) : (
        <ul class="news-list">
          {news.map((item) => (
            <li>
              <time datetime={item.data.date.toISOString()}>{dateFmt.format(item.data.date)}</time>
              <h3>
                {item.data.link ? <a href={item.data.link}>{item.data.title}</a> : item.data.title}
              </h3>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>

<style>
  /* The lockup replaces the headline text, so it is sized like a headline: large but
     capped so it never dominates on a wide screen. */
  .hero-mark {
    margin: 0 0 1.5rem;
    line-height: 0;
  }

  .hero-mark img {
    width: 100%;
    max-width: 580px;
    height: auto;
  }

  .section.first {
    margin-top: 3rem;
  }

  /* Research topics: a calm list of links, no summaries. Sans-serif like the nav for a
     clean, directory feel; hairline dividers; a muted arrow that warms to crimson on
     hover to signal it's a link. */
  .topics {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Bottom-border per row (not top) so the first row has no rule of its own — the
     section-head's underline already sits above it. A top border here would double up
     with that underline into two parallel lines. (Same pattern as the news list.) */
  .topics li {
    border-bottom: 1px solid var(--rule);
  }

  .topics a {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.9rem 0;
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 1.125rem;
    color: var(--ink);
    text-decoration: none;
  }

  .topics a::after {
    content: '→';
    color: var(--muted);
    transition: transform 0.15s ease;
  }

  .topics a:hover {
    color: var(--crimson);
  }

  .topics a:hover::after {
    color: var(--crimson);
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    .topics a::after {
      transition: none;
    }
  }

  /* Groups: PI name (→ profile) on the left, an external link to the group site on the
     right. Same calm bordered-list feel as the topics list. Padding lives on the links
     so each is a comfortable tap target rather than a thin line of text. */
  .groups {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .groups li {
    border-bottom: 1px solid var(--rule);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .groups .g-name {
    padding: 0.75rem 0;
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 1.125rem;
    color: var(--ink);
    text-decoration: none;
  }

  .groups .g-name:hover {
    color: var(--crimson);
  }

  .groups .g-site {
    padding: 0.75rem 0;
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.875rem;
    color: var(--crimson);
    text-decoration: none;
    white-space: nowrap;
    flex: none;
  }

  .groups .g-site:hover {
    text-decoration: underline;
  }

  @media (max-width: 34rem) {
    .hero-mark img {
      max-width: 100%;
    }
  }
</style>
